MONGODB_URI=mongodb+srv://username:password@cluster-url/campus-crush
JWT_SECRET=your_jwt_secret_here
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=Campus Crush <your_email@example.com>
# Optional (recommended on Render): API-based email over HTTPS
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxx
PORT=5000
FRONTEND_URL=http://localhost:5173
# Production: set to your Vercel URL(s), comma-separated, no trailing slash.
# If Vercel gives a new preview URL on each deploy, set:
# CORS_ALLOW_VERCEL_PREVIEWS=true
# to allow any https://*.vercel.app origin.
CORS_ALLOW_VERCEL_PREVIEWS=false

